# =============================================================================
# ORLO DOCS - PRODUCTION ENVIRONMENT
# =============================================================================
# Copy this file to .env.production on a self-managed server, or use it as the
# source of truth when entering environment variables in Coolify.

# Public docs deployment
NODE_ENV=production
AUTH_MODE=public
F0_MODE=docs

# Network
HOST=0.0.0.0
PORT=3000

# Site metadata
NUXT_PUBLIC_SITE_NAME=Orlo
NUXT_PUBLIC_SITE_DESCRIPTION=Orlo Documentation
NUXT_PUBLIC_SITE_URL=https://docs.useorlo.com

# Analytics (optional)
NUXT_PUBLIC_GTAG_ID=

# Only required if AUTH_MODE=private
JWT_SECRET=change-me-in-production

# Optional OTP email settings for private mode
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=no-reply@useorlo.com

# Optional webhook support
GITHUB_WEBHOOK_SECRET=

# Content directory overrides (usually not needed)
# CONTENT_DIR=./content
# PRIVATE_DIR=./private
