# =============================================================================
# ORLO DOCS ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and adjust values for your deployment.

# Public docs deployment
AUTH_MODE=public
F0_MODE=docs

# Only required if AUTH_MODE=private
JWT_SECRET=change-me-in-production

# Optional email settings for private-mode OTP auth
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=no-reply@useorlo.com

# Optional analytics
NUXT_PUBLIC_GTAG_ID=

# Site metadata
NUXT_PUBLIC_SITE_NAME=Orlo
NUXT_PUBLIC_SITE_DESCRIPTION=Orlo Documentation
NUXT_PUBLIC_SITE_URL=https://docs.useorlo.com

# Content directories
# CONTENT_DIR=./content
# PRIVATE_DIR=./private

# Optional webhook support
GITHUB_WEBHOOK_SECRET=
